{
  "name": "hilldun-ftp-automation",
  "version": "1.0.0",
  "description": "Automatización FTP con Hilldun: envío de solicitudes de crédito y descarga de respuestas",
  "main": "ftp-hilldun.js",
  "scripts": {
    "enviar": "node ftp-hilldun.js --modo=enviar",
