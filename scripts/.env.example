# ============================================
# CONFIGURACIÓN HILLDUN FTP - ftp-hilldun.js
# ============================================
# Copia este archivo como .env y rellena los valores reales
# NUNCA subas el archivo .env al repositorio

# ---- SFTP Hilldun ----
SFTP_HOST=ftp.hilldun.com
SFTP_PORT=22
SFTP_USER=XXXX
SFTP_PASSWORD=tu_password_aqui
SFTP_INBOUND=/inbound
SFTP_OUTBOUND=/outbound

# ---- Firebase ----
# Ruta al archivo JSON de la cuenta de servicio de Firebase Admin
# Descárgalo desde: Firebase Console > Configuración del proyecto > Cuentas de servicio
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
FIREBASE_PROJECT_ID=comisiones-app-33035

# ---- Directorios locales ----
# Donde se guardan los CSV generados antes de enviar
CSV_UPLOAD_DIR=./csv_pendientes
# Donde se guardan las respuestas descargadas de Hilldun
CSV_DOWNLOAD_DIR=./csv_respuestas
# Archivo de log de operaciones
LOG_FILE=./hilldun_ftp.log
